// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Đơn vị thuê bao (Cửa hàng / Doanh nghiệp) ───
model Tenant {
  id        Int      @id @default(autoincrement())
  name      String   // Tên cửa hàng
  subdomain String   @unique // Subdomain định danh (vd: "demo", "vietstore")
  phone     String?  // Số điện thoại cửa hàng
  area      String?  // Khu vực cửa hàng
  plan      String   @default("TRIAL") // TRIAL, STANDARD, PRO
  isActive  Boolean  @default(true)
  expiredAt DateTime? // Hạn sử dụng (null = vĩnh viễn)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  categories       Category[]
  products         Product[]
  brands           Brand[]
  customers        Customer[]
  suppliers        Supplier[]
  orders           Order[]
  returns          Return[]
  purchaseOrders   PurchaseOrder[]
  purchaseReturns  PurchaseReturn[]
  inventoryChecks  InventoryCheck[]
  cashbookEntries  CashbookEntry[]
  sequenceTrackers SequenceTracker[]
  cashbookPartners CashbookPartner[]
  notifications    Notification[]
}

// ─── Người dùng / Nhân viên ───
model User {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  username  String
  email     String?
  password  String
  fullName  String
  phone     String?
  role      Role     @default(STAFF)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders         Order[]
  cashbookEntries CashbookEntry[]
  inventoryChecks InventoryCheck[] @relation("UserInventoryChecks")

  @@unique([tenantId, username])
  @@unique([tenantId, email])
  @@index([username])
  @@index([email])
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}

// ─── Nhóm hàng ───
model Category {
  id        Int        @id @default(autoincrement())
  tenantId  Int
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  note      String?
  parentId  Int?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryTree")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  products Product[]

  @@unique([tenantId, name])
  @@index([name])
  @@index([parentId])
}

// ─── Hàng hóa ───
model Product {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sku         String   // Mã hàng
  name        String   // Tên hàng
  barcode     String?  // Mã vạch
  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brandId     Int?
  brand       Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  supplierId  Int?
  supplier    Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  costPrice   Decimal  @default(0) @db.Decimal(15, 2)  // Giá vốn
  sellPrice   Decimal  @default(0) @db.Decimal(15, 2)  // Giá bán
  stock       Float    @default(0)                      // Tồn kho
  minStock    Float    @default(0)                      // Tồn kho tối thiểu
  maxStock    Float    @default(999999999)              // Tồn kho tối đa
  unit        String   @default("Cái")                  // Đơn vị tính
  weight      Decimal? @db.Decimal(10, 2)               // Trọng lượng
  weightUnit  String   @default("g")                    // Đơn vị trọng lượng
  location    String?                                   // Vị trí
  description String?  @db.Text                         // Mô tả
  note        String?  @db.Text                         // Mẫu ghi chú
  image       String?
  isActive    Boolean  @default(true)
  directSale  Boolean  @default(true)                   // Bán trực tiếp
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems       OrderItem[]
  returnItems      ReturnItem[]
  purchaseItems    PurchaseOrderItem[]
  purchaseReturnItems PurchaseReturnItem[]
  inventoryCheckItems InventoryCheckItem[]

  @@unique([tenantId, sku])
  @@unique([tenantId, barcode])
  @@index([sku])
  @@index([barcode])
  @@index([name])
  @@index([categoryId])
  @@index([brandId])
  @@index([supplierId])
  @@index([isActive, categoryId])
  @@index([tenantId, isActive])
}

// ─── Thương hiệu ───
model Brand {
  id        Int       @id @default(autoincrement())
  tenantId  Int
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  products  Product[]

  @@unique([tenantId, name])
}

// ─── Khách hàng ───
model Customer {
  id              Int      @id @default(autoincrement())
  tenantId        Int
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code            String   // Mã KH
  name            String
  phone           String?
  email           String?
  address         String?
  note            String?
  customerType    String?
  branch          String?
  totalSpent      Decimal  @default(0) @db.Decimal(15, 2)
  totalDebt       Decimal  @default(0) @db.Decimal(15, 2)
  totalOrders     Int      @default(0)
  isActive        Boolean  @default(true)
  createdBy       String?
  lastTransaction DateTime?
  latitude        Float?
  longitude       Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orders  Order[]
  returns Return[]
  cashbookEntries CashbookEntry[]

  @@unique([tenantId, code])
  @@unique([tenantId, phone])
  @@index([code])
  @@index([phone])
  @@index([name])
}

// ─── Nhà cung cấp ───
model Supplier {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code        String
  name        String
  phone       String?
  email       String?
  address     String?
  note        String?
  totalSpent  Decimal  @default(0) @db.Decimal(15, 2)
  totalDebt   Decimal  @default(0) @db.Decimal(15, 2)
  isActive    Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
  purchaseReturns PurchaseReturn[]
  products       Product[]
  cashbookEntries CashbookEntry[]

  @@unique([tenantId, code])
  @@index([code])
  @@index([name])
}

// ─── Đơn hàng (Bán hàng) ───
model Order {
  id            Int         @id @default(autoincrement())
  tenantId      Int
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code          String      // Mã đơn: HD000001
  customerId    Int?
  customer      Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  userId        Int
  user          User        @relation(fields: [userId], references: [id])
  status        OrderStatus @default(COMPLETED)
  subtotal      Decimal     @default(0) @db.Decimal(15, 2)
  discount      Decimal     @default(0) @db.Decimal(15, 2)
  total         Decimal     @default(0) @db.Decimal(15, 2)
  paid          Decimal     @default(0) @db.Decimal(15, 2)
  oldDebt       Decimal?    @default(0) @db.Decimal(15, 2)
  newDebt       Decimal?    @default(0) @db.Decimal(15, 2)
  paymentMethod PaymentMethod @default(CASH)
  note          String?
  branch        String?     // Chi nhánh
  priceBook     String?     // Bảng giá
  channel       String?     // Kênh bán
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  deliveryAddress String?
  receiverName    String?
  receiverPhone   String?
  driverId        String?
  driverName      String?
  deliveryStatus  String?
  latitude        Float?
  longitude       Float?

  items   OrderItem[]
  returns Return[]
  cashbookEntries CashbookEntry[]

  @@unique([tenantId, code])
  @@index([code])
  @@index([customerId])
  @@index([userId])
  @@index([createdAt])
  @@index([status])
  @@index([status, createdAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, status, createdAt])
}

enum OrderStatus {
  COMPLETED
  CANCELLED
  PENDING
  SHIPPING
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MIXED
}

// ─── Chi tiết đơn hàng ───
model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Float
  price     Decimal @db.Decimal(15, 2)   // Giá bán tại thời điểm
  discount  Decimal @default(0) @db.Decimal(15, 2)
  total     Decimal @db.Decimal(15, 2)

  @@index([orderId])
  @@index([productId])
}

// ─── Trả hàng ───
model Return {
  id         Int          @id @default(autoincrement())
  tenantId   Int
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code       String
  orderId    Int?
  order      Order?       @relation(fields: [orderId], references: [id])
  customerId Int?
  customer   Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  total      Decimal      @default(0) @db.Decimal(15, 2)
  discount   Decimal      @default(0) @db.Decimal(15, 2) // Phí trả hàng (khách chịu)
  paid       Decimal      @default(0) @db.Decimal(15, 2) // Tiền thực tế trả khách
  reason     String?
  status     ReturnStatus @default(COMPLETED)
  createdAt  DateTime     @default(now())

  items ReturnItem[]
  cashbookEntries CashbookEntry[]

  @@unique([tenantId, code])
  @@index([code])
  @@index([orderId])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, status, createdAt])
}

enum ReturnStatus {
  COMPLETED
  CANCELLED
}

model ReturnItem {
  id        Int     @id @default(autoincrement())
  returnId  Int
  return    Return  @relation(fields: [returnId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Float
  price     Decimal @db.Decimal(15, 2)
  total     Decimal @db.Decimal(15, 2)

  @@index([returnId])
  @@index([productId])
}

// ─── Nhập hàng (Mua hàng) ───
model PurchaseOrder {
  id         Int                 @id @default(autoincrement())
  tenantId   Int
  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code       String              // PN000001
  supplierId Int
  supplier   Supplier            @relation(fields: [supplierId], references: [id])
  status     PurchaseOrderStatus @default(PENDING)
  total      Decimal             @default(0) @db.Decimal(15, 2)
  paid       Decimal             @default(0) @db.Decimal(15, 2)
  note       String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  items PurchaseOrderItem[]
  purchaseReturns PurchaseReturn[]
  cashbookEntries CashbookEntry[]

  @@unique([tenantId, code])
  @@index([code])
  @@index([supplierId])
  @@index([createdAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, status, createdAt])
}

enum PurchaseOrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model PurchaseOrderItem {
  id              Int           @id @default(autoincrement())
  purchaseOrderId Int
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       Int
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Float
  price           Decimal       @db.Decimal(15, 2)
  total           Decimal       @db.Decimal(15, 2)

  @@index([purchaseOrderId])
  @@index([productId])
}

// ─── Trả hàng nhập (Purchase Returns) ───
model PurchaseReturn {
  id              Int                  @id @default(autoincrement())
  tenantId        Int
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code            String               // THN000001
  purchaseOrderId Int?
  purchaseOrder   PurchaseOrder?       @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  supplierId      Int
  supplier        Supplier             @relation(fields: [supplierId], references: [id])
  status          PurchaseReturnStatus @default(COMPLETED)
  total           Decimal              @default(0) @db.Decimal(15, 2)
  discount        Decimal              @default(0) @db.Decimal(15, 2) // Giảm giá
  paid            Decimal              @default(0) @db.Decimal(15, 2) // Tiền NCC trả
  note            String?
  createdBy       String?              // Người tạo
  receivedBy      String?              // Người trả
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  items PurchaseReturnItem[]

  @@unique([tenantId, code])
  @@index([code])
  @@index([purchaseOrderId])
  @@index([supplierId])
  @@index([createdAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, status, createdAt])
}

enum PurchaseReturnStatus {
  PENDING   // Phiếu tạm
  COMPLETED // Đã trả hàng
  CANCELLED // Đã hủy
}

model PurchaseReturnItem {
  id               Int            @id @default(autoincrement())
  purchaseReturnId Int
  purchaseReturn   PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  productId        Int
  product          Product        @relation(fields: [productId], references: [id])
  quantity         Float          // Số lượng trả
  unit             String         @default("Cái") // Đơn vị tính
  price            Decimal        @db.Decimal(15, 2) // Giá nhập
  returnPrice      Decimal        @db.Decimal(15, 2) // Giá trả lại
  total            Decimal        @db.Decimal(15, 2) // Thành tiền
  note             String?        // Ghi chú dòng sản phẩm

  @@index([purchaseReturnId])
  @@index([productId])
}

// ─── Kiểm kho ───
model InventoryCheck {
  id            Int      @id @default(autoincrement())
  tenantId      Int
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code          String   // KK000001
  userId        Int?
  user          User?    @relation("UserInventoryChecks", fields: [userId], references: [id])
  status        String   @default("COMPLETED") // PENDING, COMPLETED, CANCELLED
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items InventoryCheckItem[]

  @@unique([tenantId, code])
  @@index([code])
  @@index([createdAt])
  @@index([tenantId, createdAt])
}

model InventoryCheckItem {
  id               Int            @id @default(autoincrement())
  inventoryCheckId Int
  inventoryCheck   InventoryCheck @relation(fields: [inventoryCheckId], references: [id], onDelete: Cascade)
  productId        Int
  product          Product        @relation(fields: [productId], references: [id])
  systemQty        Float          // Tồn hệ thống
  actualQty        Float          // Tồn thực tế
  difference       Float          // Chênh lệch
  note             String?

  @@index([inventoryCheckId])
  @@index([productId])
}

// ─── Sổ quỹ ───
model CashbookEntry {
  id             Int            @id @default(autoincrement())
  tenantId       Int
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code           String         // TTM000001
  type           CashbookType
  amount         Decimal        @db.Decimal(15, 2)
  description    String?
  userId         Int
  user           User           @relation(fields: [userId], references: [id])
  category       String         @default("Thu nhập khác") // Loại thu/chi (VD: Thu nhập khác, Chi phí khác, Chuyển/Rút)
  
  // Relations for tracing origins
  orderId        Int?
  order          Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  purchaseOrderId Int?
  purchaseOrder  PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  returnId       Int?
  return         Return?        @relation(fields: [returnId], references: [id], onDelete: SetNull)

  // Partner Relations
  partnerType    String         @default("other") // customer, supplier, staff, delivery, other
  customerId     Int?
  customer       Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  supplierId     Int?
  supplier       Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  
  partnerName    String
  partnerPhone   String?
  partnerAddress String?
  paymentMethod  String         @default("cash") // cash, bank, wallet
  isAccounting   Boolean        @default(true) // Hạch toán kết quả kinh doanh
  status         String         @default("completed") // completed (Đã thanh toán), cancelled (Đã hủy)
  branch         String?        @default("Chi nhánh trung tâm")
  createdBy      String?        @default("Võ Thành Huy")
  note           String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([tenantId, code])
  @@index([type])
  @@index([createdAt])
  @@index([userId])
  @@index([customerId])
  @@index([supplierId])
  @@index([orderId])
  @@index([purchaseOrderId])
  @@index([type, createdAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, type, createdAt])
}

enum CashbookType {
  INCOME
  EXPENSE
}

model CashbookPartner {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String   // Tên người nhận/nộp
  phone     String?  // Điện thoại
  address   String?  // Địa chỉ
  province  String?  // Tỉnh/Thành phố
  ward      String?  // Phường/Xã
  note      String?  // Ghi chú
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
}

// ─── Sequence Tracker (Tạo mã tăng tự động chống Race Condition) ───
model SequenceTracker {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String   // e.g. "ORDER", "PURCHASE_ORDER", "INVENTORY_CHECK", "CASHBOOK"
  value     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
}

// ─── Super Admin (Quản trị hệ thống SaaS) ───
model SuperAdmin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  fullName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Thông báo (Real-time Notifications) ───
model Notification {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("ORDER_STATUS") // ORDER_STATUS, SYSTEM, etc.
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, isRead])
}
